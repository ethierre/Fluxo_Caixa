{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "FluxoCaixaCarrefour_SecretKey_256bits_Dev!",
    "Issuer": "FluxoCaixa.Gateway",
    "Audience": "FluxoCaixa.Services",
    "ExpirationMinutes": 60
  },
  "ReverseProxy": {
    "Routes": {
      "lancamentosRoute": {
        "ClusterId": "lancamentosCluster",
        "Match": {
          "Path": "/api/lancamentos/{**catch-all}"
        }
      },
      "consolidadoRoute": {
        "ClusterId": "consolidadoCluster",
        "Match": {
          "Path": "/api/consolidado/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "lancamentosCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://lancamentos-api:8080"
          }
        }
      },
      "consolidadoCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://consolidado-api:8080"
          }
        }
      }
    }
  }
}
